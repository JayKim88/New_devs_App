# General
.git
.gitignore
node_modules
frontend/node_modules
__pycache__/
*.pyc
*.pyo
*.pyd

# OS / editor
.DS_Store
*.swp
.vscode/
.idea/

# Env / secrets
# NOTE: frontend/.env contains VITE_BACKEND_URL which Vite bakes into the bundle
# at build time. Excluding it here made the bundle ship with "undefined/api/v1"
# as baseURL, causing all API calls to fall through to nginx SPA fallback.
# .env  ← intentionally NOT excluded for frontend build
.kamal.env

# Build output
frontend/dist
